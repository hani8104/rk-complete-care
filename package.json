{
    "name": "rk-complete-care",
    "version": "1.0.0",
    "description": "RK The Complete Care - MERN Stack Project",
    "main": "index.js",
    "scripts": {
        "start": "node server/index.js",
        "build:prod": "npm install && cd client && npm install && npm run build && cd ../server && npm install",
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "cd client && npm run dev",
        "dev:server": "cd server && npm run dev",
        "build": "concurrently \"npm run build:client\" \"npm run build:server\"",
        "build:client": "cd client && npm run build",
        "build:server": "cd server && npm run build",
        "install:all": "concurrently \"npm run install:client\" \"npm run install:server\"",
        "install:client": "cd client && npm install",
        "install:server": "cd server && npm install"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "concurrently": "^8.2.2",
        "mongodb": "^7.1.0"
    }
}
